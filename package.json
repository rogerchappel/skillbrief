{
  "name": "skillbrief",
  "version": "0.1.0",
  "description": "Traceable repo-to-content brief generator for launch posts and demo preparation.",
  "main": "src/index.js",
  "bin": {
    "skillbrief": "src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/cli.js",
    "smoke": "node src/cli.js fixtures/example.json",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "local-first",
    "dry-run"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillbrief.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillbrief/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillbrief#readme",
  "author": "Roger Chappel",
  "license": "MIT",
  "files": [
    "src",
    "fixtures",
    "docs",
    "scripts",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ]
}
